{
  "name": "Stale ping: In Progress > 3d",
  "enabled": true,
  "ruleScope": { "type": "PROJECT" },
  "projects": ["WXT"],
  "triggers": [
    { "type": "scheduled", "schedule": "0 9 * * *" }
  ],
  "conditions": [
    {
      "type": "jql",
      "jql": "project = WXT AND status = 'In Progress' AND updated < -3d"
    }
  ],
  "actions": [
    { "type": "addComment", "comment": "Stale: no updates for 3 days" }
  ]
}
