#!/bin/bash

# Git Hook: commit-msg
# 자동으로 개발 로그에 커밋 정보를 기록하는 스크립트
# 설치: cp scripts/git-hooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg

set -e

# 색상 정의
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 로그 함수
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

# 커밋 메시지 파일 경로
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# 현재 날짜와 시간
DATE=$(date +"%Y-%m-%d")
TIME=$(date +"%H:%M:%S")
TIMESTAMP=$(date +"%Y-%m-%d %H:%M:%S")

# 프로젝트 루트 디렉토리
PROJECT_ROOT=$(git rev-parse --show-toplevel)
DEV_LOGS_DIR="$PROJECT_ROOT/dev-logs"
DAILY_LOG_DIR="$DEV_LOGS_DIR/daily-logs"
ISSUE_LOGS_DIR="$DEV_LOGS_DIR/issue-logs"

# 브랜치 정보
CURRENT_BRANCH=$(git branch --show-current)
COMMIT_HASH=$(git rev-parse --short HEAD 2>/dev/null || echo "pending")

log_info "Processing commit message: $COMMIT_MSG"
log_info "Current branch: $CURRENT_BRANCH"

# WXT 이슈 키 추출 (WXT-123 형식) 및 Jira 정보 조회
WXT_ISSUE=$(echo "$COMMIT_MSG" | grep -oE 'WXT-[0-9]+' | head -1)
JIRA_SUMMARY=""
JIRA_INFO=""

# 브랜치에서 이슈 키 추출 (커밋 메시지에 없으면)
if [[ -z "$WXT_ISSUE" ]]; then
    WXT_ISSUE=$(echo "$CURRENT_BRANCH" | grep -oE 'WXT-[0-9]+' | head -1)
    if [[ -n "$WXT_ISSUE" ]]; then
        log_info "Found WXT issue from branch: $WXT_ISSUE"
        # 커밋 메시지에 이슈 키 자동 추가
        if ! echo "$COMMIT_MSG" | grep -q "$WXT_ISSUE"; then
            printf '%s: %s\n' "$WXT_ISSUE" "$COMMIT_MSG" > "$COMMIT_MSG_FILE"
            COMMIT_MSG="$WXT_ISSUE: $COMMIT_MSG"
            log_info "Added WXT issue key to commit message"
        fi
    fi
fi

# Jira 정보 추출 (WXT 이슈가 있는 경우)
if [[ -n "$WXT_ISSUE" ]]; then
    JIRA_PARSER="$PROJECT_ROOT/scripts/jira-issue-parser.sh"
    if [[ -f "$JIRA_PARSER" ]]; then
        log_info "🔍 Querying Jira data for $WXT_ISSUE..."
        # 간단한 Jira 요약 추출기 사용
        JIRA_SUMMARY_SCRIPT="$PROJECT_ROOT/scripts/jira-summary.sh"
        if [[ -f "$JIRA_SUMMARY_SCRIPT" ]]; then
            JIRA_SUMMARY=$(bash "$JIRA_SUMMARY_SCRIPT" "$WXT_ISSUE" 2>/dev/null)
        else
            # 수동 매핑 (알려진 이슈들)
            case "$WXT_ISSUE" in
                "WXT-57") JIRA_SUMMARY="Route Polyline 스타일 + 진행 구간 하이라이트" ;;
                "WXT-56") JIRA_SUMMARY="Turn Banner + 진행 바" ;;
                "WXT-55") JIRA_SUMMARY="MapOverlay HUD (속도/제한속도/거리·ETA)" ;;
                "WXT-54") JIRA_SUMMARY="유닛/서버 테스트 (FPS ≥ 45, First Paint ≤ 2s)" ;;
                "WXT-53") JIRA_SUMMARY="성능 계측 & CSV export" ;;
                "WXT-52") JIRA_SUMMARY="MapPanel DrawPolyline 연동 + ack 로깅" ;;
                "WXT-51") JIRA_SUMMARY="add RenderPipeline skeleton (§3.0/§3.1)" ;;
                *) JIRA_SUMMARY="" ;;
            esac
        fi
        if [[ -n "$JIRA_SUMMARY" ]]; then
            JIRA_INFO=" [$JIRA_SUMMARY]"
            log_info "📋 Jira: $JIRA_SUMMARY"
        else
            log_warning "Could not extract Jira summary for $WXT_ISSUE"
        fi
    fi
fi

# 커밋 메시지에서 WXT 이슈 키가 없으면 경고
if [[ -z "$WXT_ISSUE" ]]; then
    log_warning "No WXT issue key found in commit message or branch!"
    log_warning "Recommended format: 'WXT-123: description'"
    log_warning "Continuing without issue tracking..."
fi

# dev-logs 디렉토리 존재 확인
if [[ ! -d "$DEV_LOGS_DIR" ]]; then
    log_warning "Dev logs directory not found: $DEV_LOGS_DIR"
    log_info "Creating dev-logs structure..."
    mkdir -p "$DAILY_LOG_DIR" "$ISSUE_LOGS_DIR"
fi

# 일일 로그 파일 경로
DAILY_LOG_FILE="$DAILY_LOG_DIR/$DATE.md"

# 일일 로그 파일이 없으면 생성
if [[ ! -f "$DAILY_LOG_FILE" ]]; then
    log_info "Creating daily log file: $DAILY_LOG_FILE"
    cat > "$DAILY_LOG_FILE" << EOF
# 일일 개발 로그 - $DATE

> 📅 **날짜**: $(date +"%Y년 %m월 %d일")  
> 👤 **작업자**: $(git config user.name)  
> 🌿 **브랜치**: $CURRENT_BRANCH  
> 🎯 **주요 작업**: 개발 진행 중

## 📋 오늘의 주요 활동

### Git 커밋 기록
EOF
fi

# 일일 로그에 커밋 정보 추가
log_info "Adding commit to daily log..."
cat >> "$DAILY_LOG_FILE" << EOF

#### $TIME - Git Commit ($COMMIT_HASH)
- **브랜치**: \`$CURRENT_BRANCH\`
- **WXT 이슈**: $WXT_ISSUE$JIRA_INFO
- **커밋**: \`$COMMIT_MSG\`
EOF

# WXT 이슈가 있으면 이슈별 로그도 업데이트
if [[ -n "$WXT_ISSUE" ]]; then
    log_info "Found WXT issue: $WXT_ISSUE"
    
    # 이슈별 로그 파일 찾기
    ISSUE_LOG_FILE=$(find "$ISSUE_LOGS_DIR" -name "$WXT_ISSUE-*.md" | head -1)
    
    if [[ -f "$ISSUE_LOG_FILE" ]]; then
        log_info "Updating issue log: $ISSUE_LOG_FILE"
        
        # 개발 진행 상황 섹션 찾기 및 업데이트
        if grep -q "## 📈 개발 진행 상황" "$ISSUE_LOG_FILE"; then
            # 임시 파일 생성
            TEMP_FILE=$(mktemp)
            
            # 개발 진행 상황 섹션 전까지 복사
            sed '/## 📈 개발 진행 상황/q' "$ISSUE_LOG_FILE" > "$TEMP_FILE"
            
            # 새로운 커밋 정보 추가
            cat >> "$TEMP_FILE" << EOF

### Git Commit - $TIMESTAMP
- **커밋 해시**: \`$COMMIT_HASH\`
- **브랜치**: \`$CURRENT_BRANCH\`
- **메시지**: $COMMIT_MSG
- **작업자**: $(git config user.name)

EOF
            
            # 나머지 내용 추가 (개발 진행 상황 섹션 이후)
            sed -n '/## 📈 개발 진행 상황/,$p' "$ISSUE_LOG_FILE" | tail -n +2 >> "$TEMP_FILE"
            
            # 원본 파일 교체
            mv "$TEMP_FILE" "$ISSUE_LOG_FILE"
            log_success "Issue log updated successfully"
        else
            log_warning "Could not find progress section in issue log"
        fi
    else
        log_warning "Issue log file not found for $WXT_ISSUE"
        log_info "Available issue logs:"
        ls -la "$ISSUE_LOGS_DIR" | grep "WXT-" || log_warning "No WXT issue logs found"
    fi
fi

# 커밋 통계 수집
TOTAL_COMMITS=$(git rev-list HEAD --count 2>/dev/null || echo "0")
FILES_CHANGED=$(git diff --cached --name-only | wc -l)
LINES_ADDED=$(git diff --cached --numstat | awk '{added += $1} END {print added+0}')
LINES_REMOVED=$(git diff --cached --numstat | awk '{removed += $2} END {print removed+0}')

# 일일 로그에 통계 정보 추가
cat >> "$DAILY_LOG_FILE" << EOF
- **파일 변경**: $FILES_CHANGED개
- **라인 추가**: +$LINES_ADDED
- **라인 삭제**: -$LINES_REMOVED
- **총 커밋**: $TOTAL_COMMITS개

EOF

# 성능 메트릭이 있으면 추가
METRICS_FILE="$PROJECT_ROOT/app/metrics_test.csv"
if [[ -f "$METRICS_FILE" ]]; then
    CURRENT_FPS=$(tail -1 "$METRICS_FILE" | cut -d',' -f2)
    if [[ -n "$CURRENT_FPS" ]]; then
        cat >> "$DAILY_LOG_FILE" << EOF
- **현재 FPS**: $CURRENT_FPS

EOF
    fi
fi

# Smart Commit 형식 검증
if [[ "$COMMIT_MSG" =~ WXT-[0-9]+.*#time.*#comment.*#transition ]]; then
    log_success "Smart Commit format detected - excellent!"
elif [[ "$COMMIT_MSG" =~ WXT-[0-9]+ ]]; then
    log_info "WXT issue key found - good practice!"
    log_info "Consider using Smart Commit format: WXT-123 #time 2h #comment description #done"
else
    log_warning "Consider including WXT issue key in commit message"
fi

# 커밋 메시지 길이 검증
MSG_LENGTH=${#COMMIT_MSG}
if [[ $MSG_LENGTH -lt 10 ]]; then
    log_warning "Commit message is very short ($MSG_LENGTH chars). Consider adding more detail."
elif [[ $MSG_LENGTH -gt 72 ]]; then
    log_warning "Commit message first line is long ($MSG_LENGTH chars). Consider keeping under 72 chars."
fi

log_success "Development log updated successfully!"
log_info "Daily log: $DAILY_LOG_FILE"
if [[ -n "$WXT_ISSUE" && -f "$ISSUE_LOG_FILE" ]]; then
    log_info "Issue log: $ISSUE_LOG_FILE"
fi

exit 0