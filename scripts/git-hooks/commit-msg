#!/bin/bash

# Git Hook: commit-msg
# 브랜치명에서 WXT 이슈 키를 추출하여 커밋 메시지 앞에 자동으로 추가
# 설치: cp scripts/git-hooks/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg

# 커밋 메시지 파일 경로
COMMIT_MSG_FILE="$1"

# 커밋 메시지 파일이 존재하는지 확인
if [[ ! -f "$COMMIT_MSG_FILE" ]]; then
    echo "Error: Commit message file not found: $COMMIT_MSG_FILE"
    exit 1
fi

# 현재 커밋 메시지 읽기
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# 커밋 메시지에 이미 WXT 이슈 키가 있는지 확인
if echo "$COMMIT_MSG" | grep -q '^WXT-[0-9]\+:'; then
    # 이미 이슈 키가 있으면 그대로 통과
    exit 0
fi

# 현재 브랜치 이름 가져오기
CURRENT_BRANCH=$(git branch --show-current 2>/dev/null)

# 브랜치명에서 WXT 이슈 키 추출 (WXT-123 형식)
WXT_ISSUE=$(echo "$CURRENT_BRANCH" | grep -oE 'WXT-[0-9]+' | head -1)

# WXT 이슈 키가 있으면 커밋 메시지 앞에 추가
if [[ -n "$WXT_ISSUE" ]]; then
    echo "$WXT_ISSUE: $COMMIT_MSG" > "$COMMIT_MSG_FILE"
    echo "✅ Added WXT issue key to commit message: $WXT_ISSUE"
fi

exit 0